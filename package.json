{
  "name": "open-dispatch",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:server": "turbo dev --filter=@opendispatch/server",
    "dev:web": "turbo dev --filter=@opendispatch/web",
    "db:generate": "turbo db:generate --filter=@opendispatch/db",
    "db:migrate": "turbo db:migrate --filter=@opendispatch/db",
    "test": "vitest run",
    "test:watch": "vitest",
    "chrome": "bash scripts/chrome-cdp.sh",
    "chrome:install": "cp scripts/com.opendispatch.chrome-cdp.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.opendispatch.chrome-cdp.plist && echo 'Chrome CDP will launch on login'"
  },
  "packageManager": "npm@10.9.7",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "turbo": "^2",
    "typescript": "^5.8",
    "vitest": "^4.1.2"
  }
}
